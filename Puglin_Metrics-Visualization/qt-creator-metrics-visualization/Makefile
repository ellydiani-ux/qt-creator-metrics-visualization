	-$(INSTALL_PROGRAM) "../../build/qt-creator/lib/qtcreator/plugins/LiveBlue/$(TARGET)" "$(INSTALL_ROOT)/lib/qtcreator/plugins/LiveBlue/$(TARGET)"
	-$(STRIP) --strip-unneeded "$(INSTALL_ROOT)/lib/qtcreator/plugins/LiveBlue/$(TARGET)"

uninstall_target:  FORCE
	-$(DEL_FILE) "$(INSTALL_ROOT)/lib/qtcreator/plugins/LiveBlue/$(TARGET)"
	-$(DEL_DIR) $(INSTALL_ROOT)/lib/qtcreator/plugins/LiveBlue/ 


install_pluginspec: first FORCE
	@$(CHK_DIR_EXISTS) $(INSTALL_ROOT)/lib/qtcreator/plugins/LiveBlue/ || $(MKDIR) $(INSTALL_ROOT)/lib/qtcreator/plugins/LiveBlue/ 
	-$(INSTALL_FILE) /home/elidiane/TCC/devel/src/qt-creator-metrics-visualization/VisualizationPlugin.pluginspec $(INSTALL_ROOT)/lib/qtcreator/plugins/LiveBlue/


uninstall_pluginspec:  FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/lib/qtcreator/plugins/LiveBlue/VisualizationPlugin.pluginspec
	-$(DEL_DIR) $(INSTALL_ROOT)/lib/qtcreator/plugins/LiveBlue/ 


install:  install_target install_pluginspec  FORCE

uninstall: uninstall_target uninstall_pluginspec   FORCE

